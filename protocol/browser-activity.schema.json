{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drpc.dev/schemas/browser-activity.schema.json",
  "title": "drpc Browser Activity Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "browser",
    "url",
    "host",
    "pageTitle",
    "playbackState",
    "activityDisposition",
    "sentAtUnixMs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 2
    },
    "browser": {
      "type": "string",
      "minLength": 1
    },
    "tabId": {
      "type": [
        "integer",
        "null"
      ]
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "host": {
      "type": "string"
    },
    "pageTitle": {
      "type": "string"
    },
    "siteId": {
      "type": "string"
    },
    "playbackState": {
      "type": "string",
      "enum": [
        "idle",
        "playing",
        "paused"
      ]
    },
    "activityDisposition": {
      "type": "string",
      "enum": [
        "publish",
        "sticky",
        "clear"
      ]
    },
    "activityCard": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "details": { "type": "string" },
        "detailsUrl": { "type": "string" },
        "state": { "type": "string" },
        "stateUrl": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["playing", "watching", "listening", "streaming", "customStatus", "competing", "hangStatus"]
        },
        "statusDisplayType": {
          "type": "string",
          "enum": ["name", "details", "state"]
        },
        "showElapsedTime": { "type": "boolean" },
        "startedAtUnixSeconds": {
          "type": [
            "integer",
            "null"
          ]
        },
        "endAtUnixSeconds": {
          "type": [
            "integer",
            "null"
          ]
        },
        "assets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "largeImage": { "type": "string" },
            "largeText": { "type": "string" },
            "largeUrl": { "type": "string" },
            "smallImage": { "type": "string" },
            "smallText": { "type": "string" },
            "smallUrl": { "type": "string" }
          }
        },
        "buttons": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "url"],
            "properties": {
              "label": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "sentAtUnixMs": {
      "type": "integer"
    }
  }
}
