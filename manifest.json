{
  "manifest_version": 3,
  "name": "drpc Browser Activity",
  "version": "0.1.0",
  "description": "Collect browser video activity and forward it to drpc over native messaging.",
  "permissions": [
    "alarms",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.crunchyroll.com/*",
    "https://*.hidive.com/*",
    "https://*.9animetv.to/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "drpc Browser Activity"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.crunchyroll.com/*",
        "https://*.hidive.com/*",
        "https://*.9animetv.to/*"
      ],
      "js": [
        "src/site-registry.js",
        "src/sites/crunchyroll.js",
        "src/sites/hidive.js",
        "src/sites/9anime.js",
        "src/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
