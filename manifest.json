{
  "manifest_version": 3,
  "name": "drpc Browser Activity",
  "version": "0.1.0",
  "description": "Collect browser video activity and forward it to drpc over native messaging.",
  "permissions": [
    "alarms",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.crunchyroll.com/*",
    "https://*.hidive.com/*",
    "https://*.9animetv.to/*",
    "https://*.netflix.com/*"
  ],
  "background": {
    "service_worker": "dist/src/background.js"
  },
  "action": {
    "default_title": "drpc Browser Activity",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.crunchyroll.com/*",
        "https://*.hidive.com/*",
        "https://*.9animetv.to/*",
        "https://*.netflix.com/*"
      ],
      "js": [
        "site-config.js",
        "dist/src/site-registry.js",
        "dist/src/snapshot-gate.js",
        "dist/src/sites/crunchyroll.js",
        "dist/src/sites/hidive.js",
        "dist/src/sites/9anime.js",
        "dist/src/sites/netflix.js",
        "dist/src/content-script.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/src/frame-media-probe.js"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ]
}
